# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/neura
PORT=3000
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_GENERATIVE_AI_API_KEY=...
