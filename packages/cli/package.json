{
  "name": "@mclean-capital/neura",
  "version": "1.9.0",
  "description": "Neura — CLI for installing and managing the Neura AI assistant core service. Includes text chat and voice listen clients.",
  "keywords": [
    "neura",
    "ai",
    "voice-assistant",
    "cli",
    "grok",
    "gemini",
    "llm",
    "voice",
    "speech",
    "mclean-capital"
  ],
  "homepage": "https://github.com/mclean-capital/neura#readme",
  "bugs": {
    "url": "https://github.com/mclean-capital/neura/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mclean-capital/neura.git",
    "directory": "packages/cli"
  },
  "license": "MIT",
  "author": "McLean Capital",
  "type": "module",
  "bin": {
    "neura": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@inquirer/prompts": "^7",
    "chalk": "^5",
    "commander": "^13",
    "ws": "^8.20.0"
  },
  "optionalDependencies": {
    "@picovoice/pvspeaker-node": "^1.0.3",
    "decibri": "^1.0.0",
    "speaker": "^0.5.5"
  },
  "devDependencies": {
    "@neura/types": "*",
    "@types/node": "^25",
    "@types/ws": "^8.18.1",
    "tsx": "^4"
  }
}
