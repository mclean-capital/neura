{
  "name": "@neura/desktop",
  "productName": "Neura",
  "version": "0.0.0",
  "description": "Neura desktop client",
  "author": "Mclean Capital",
  "private": true,
  "type": "module",
  "main": "dist-main/index.mjs",
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "build": "npm run build:renderer && npm run build:main && npm run build:preload",
    "build:main": "vite build --config vite.main.config.ts",
    "build:preload": "vite build --config vite.preload.config.ts",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@neura/design-system": "*",
    "@neura/shared": "*",
    "@tailwindcss/vite": "^4",
    "electron-store": "^10",
    "electron-updater": "^6",
    "express": "^4",
    "http-proxy-middleware": "^3",
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^4"
  },
  "devDependencies": {
    "@types/express": "^5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4",
    "electron": "35.7.5",
    "electron-builder": "^26",
    "tsx": "^4",
    "vite": "^6"
  }
}
