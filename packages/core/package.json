{
  "name": "@neura/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server/dev-server.ts",
    "start": "tsx src/server/dev-server.ts",
    "build": "tsc -p tsconfig.json && tsx scripts/bundle.ts",
    "bundle": "tsx scripts/bundle.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@deepgram/sdk": "^5.0.0",
    "@electric-sql/pglite": "^0.4.3",
    "@google/genai": "^1",
    "@mariozechner/pi-coding-agent": "^0.66.1",
    "chokidar": "^5.0.0",
    "express": "^4",
    "onnxruntime-web": "^1.24.3",
    "openai": "^6.26.0",
    "ws": "^8"
  },
  "optionalDependencies": {
    "onnxruntime-node": "^1.24.3"
  },
  "devDependencies": {
    "@neura/types": "*",
    "@neura/utils": "*",
    "@types/express": "^5",
    "@types/ws": "^8",
    "dotenv": "^16",
    "esbuild": "^0.25.12",
    "tsx": "^4"
  }
}
