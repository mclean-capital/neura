{
  "name": "neura",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "start": "node --env-file=.env dist/index.js",
    "build": "tsc",
    "db:init": "psql \"$DATABASE_URL\" -f src/db/schema.sql && psql \"$DATABASE_URL\" -f src/db/seed.sql",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.0",
    "@ai-sdk/anthropic": "^3.0.0",
    "@ai-sdk/google": "^3.0.0",
    "@ai-sdk/mcp": "^1.0.0",
    "@ai-sdk/openai": "^3.0.0",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "ai": "^6.0.0",
    "express": "^5.0.0",
    "pg": "^8.0.0",
    "pino": "^10.0.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.0.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.56.1"
  }
}
